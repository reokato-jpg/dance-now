generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id            String         @id @default(uuid())
  phone         String         @unique
  email         String?        @unique
  lastName      String?        @map("last_name")
  firstName     String?        @map("first_name")
  birthday      DateTime?
  genres        String[]
  totalBookings Int            @default(0) @map("total_bookings")
  totalSpent    Int            @default(0) @map("total_spent")
  lastBookedAt  DateTime?      @map("last_booked_at")
  tag           CustomerTag    @default(NEW)
  createdAt     DateTime       @default(now()) @map("created_at")
  bookings      Booking[]
  notifications Notification[]

  @@map("customers")
}

enum CustomerTag {
  NEW
  REGULAR
  FREQUENT
  VIP
}

model Studio {
  id           String   @id @default(uuid())
  name         String
  address      String
  capacity     Int
  pricePerHour Int      @default(3000) @map("price_per_hour")
  openAt       String   @map("open_at")
  closeAt      String   @map("close_at")
  slots        Slot[]
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("studios")
}

model Slot {
  id          String    @id @default(uuid())
  studio      Studio    @relation(fields: [studioId], references: [id])
  studioId    String    @map("studio_id")
  startAt     DateTime  @map("start_at")
  durationMin Int       @default(60) @map("duration_min")
  capacity    Int       @default(1)
  price       Int
  bookings    Booking[]
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("slots")
}

model Booking {
  id             String        @id @default(uuid())
  reservationNo  String        @unique @map("reservation_no")
  customer       Customer      @relation(fields: [customerId], references: [id])
  customerId     String        @map("customer_id")
  slot           Slot          @relation(fields: [slotId], references: [id])
  slotId         String        @map("slot_id")
  status         BookingStatus @default(CONFIRMED)
  amount         Int
  discountAmount Int           @default(0) @map("discount_amount")
  coupon         Coupon?       @relation(fields: [couponId], references: [id])
  couponId       String?       @map("coupon_id")
  payment        Payment?
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("bookings")
}

enum BookingStatus {
  CONFIRMED
  ATTENDED
  CANCELLED
  NO_SHOW
}

model Payment {
  id            String        @id @default(uuid())
  booking       Booking       @relation(fields: [bookingId], references: [id])
  bookingId     String        @unique @map("booking_id")
  method        PaymentMethod
  providerTxnId String?       @map("provider_txn_id")
  amount        Int
  status        PaymentStatus @default(PENDING)
  refundAmount  Int           @default(0) @map("refund_amount")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("payments")
}

enum PaymentMethod {
  STRIPE
  PAYPAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType @map("discount_type")
  discountValue Int          @map("discount_value")
  validUntil    DateTime?    @map("valid_until")
  usageLimit    Int?         @map("usage_limit")
  usageCount    Int          @default(0) @map("usage_count")
  isActive      Boolean      @default(true) @map("is_active")
  bookings      Booking[]
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("coupons")
}

enum DiscountType {
  PERCENT
  FIXED
}

model Notification {
  id         String           @id @default(uuid())
  customer   Customer         @relation(fields: [customerId], references: [id])
  customerId String           @map("customer_id")
  type       NotificationType
  sentAt     DateTime?        @map("sent_at")
  openedAt   DateTime?        @map("opened_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

enum NotificationType {
  BOOKING_CONFIRMED
  REMINDER
  CANCEL_REFUND
  COUPON
}
